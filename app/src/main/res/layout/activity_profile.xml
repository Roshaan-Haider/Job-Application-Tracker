<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:fillViewport="true"
    tools:context=".ProfileActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_xl"
        android:paddingBottom="@dimen/space_xxl">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_teal_dim"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary" />

        <!-- Avatar + identity -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:gravity="center"
            android:orientation="vertical">

            <FrameLayout
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/circle_teal_dim">

                <TextView
                    android:id="@+id/txtAvatarInitial"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="J"
                    android:textColor="@color/accent_teal"
                    android:textSize="32sp"
                    android:textStyle="bold" />

            </FrameLayout>

            <TextView
                android:id="@+id/txtUserName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="Jane Doe"
                android:textColor="@color/text_primary"
                android:textSize="@dimen/text_h3"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/txtUserEmail"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="jane@example.com"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_body_small" />

        </LinearLayout>

        <!-- ACCOUNT section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:layout_marginStart="@dimen/space_xs"
            android:text="ACCOUNT"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_label"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/card_flat"
            android:orientation="vertical">

            <!-- Change password -->
            <LinearLayout
                android:id="@+id/optionChangePassword"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_lock"
                    app:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_md"
                    android:text="Change Password"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_play"
                    android:rotation="0"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="54dp"
                android:background="@color/border_subtle" />

            <!-- Edit profile -->
            <LinearLayout
                android:id="@+id/optionEditProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_person"
                    app:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_md"
                    android:text="Edit Profile"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- PREFERENCES section -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:layout_marginStart="@dimen/space_xs"
            android:text="PREFERENCES"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_label"
            android:letterSpacing="0.1" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:background="@drawable/card_flat"
            android:orientation="vertical">

            <!-- Notifications -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_popup_reminder"
                    app:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_md"
                    android:text="Notifications"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchNotifications"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:thumbTint="@color/text_primary"
                    app:trackTint="@color/border_subtle"
                    android:checked="true" />

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="54dp"
                android:background="@color/border_subtle" />

            <!-- About -->
            <LinearLayout
                android:id="@+id/optionAbout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/space_md"
                android:clickable="true"
                android:focusable="true"
                android:background="?attr/selectableItemBackground">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@android:drawable/ic_menu_info_details"
                    app:tint="@color/accent_teal" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/space_md"
                    android:text="About JobTracker"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body" />

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@android:drawable/ic_media_play"
                    app:tint="@color/text_secondary" />

            </LinearLayout>

        </LinearLayout>

        <!-- Logout button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnLogout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="@dimen/space_xl"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            android:text="Log Out"
            android:textAllCaps="false"
            android:textColor="@color/status_error"
            android:textSize="@dimen/text_body"
            android:textStyle="bold"
            app:backgroundTint="@color/bg_surface"
            app:cornerRadius="@dimen/radius_sm"
            app:strokeColor="@color/status_error"
            app:strokeWidth="1dp"
            app:rippleColor="#22F85149" />

    </LinearLayout>
</ScrollView>