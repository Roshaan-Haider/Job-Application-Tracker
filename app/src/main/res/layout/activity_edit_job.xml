<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deepest"
    android:fillViewport="true"
    tools:context=".EditJobActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_lg"
        android:paddingTop="@dimen/space_xl"
        android:paddingBottom="@dimen/space_xxl">

        <!-- Back arrow -->
        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/circle_teal_dim"
            android:contentDescription="Back"
            android:padding="10dp"
            android:src="@android:drawable/ic_menu_revert"
            app:tint="@color/text_primary" />

        <!-- Hero text -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_md"
            android:text="Edit Application"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_h1"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="Edit Job Application "
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_body" />

        <!-- Form Card -->
        <LinearLayout
            android:id="@+id/formCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xl"
            android:background="@drawable/card_flat"
            android:orientation="vertical"
            android:padding="@dimen/space_lg">

            <!-- Company -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="COMPANY"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.1" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxStrokeColor="@color/border_subtle"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_agenda"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/companyInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. Google"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Job Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="JOB TITLE"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.1" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxStrokeColor="@color/border_subtle"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_manage"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/titleInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. Android Developer"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Salary -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="SALARY (OPTIONAL)"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.1" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxStrokeColor="@color/border_subtle"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_sort_by_size"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/salaryInput"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="e.g. 120,000"
                    android:inputType="number"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Status dropdown -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="STATUS"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.1" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.ExposedDropdownMenu"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxStrokeColor="@color/border_subtle"
                app:hintEnabled="false"
                app:endIconTint="@color/text_secondary">

                <AutoCompleteTextView
                    android:id="@+id/autoCompleteTextView"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:hint="Applied"
                    android:inputType="none"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Date -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:text="DATE APPLIED"
                android:textColor="@color/text_secondary"
                android:textSize="@dimen/text_label"
                android:letterSpacing="0.1" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                app:boxBackgroundColor="@color/bg_surface"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusBottomEnd="@dimen/radius_md"
                app:boxCornerRadiusBottomStart="@dimen/radius_md"
                app:boxCornerRadiusTopEnd="@dimen/radius_md"
                app:boxCornerRadiusTopStart="@dimen/radius_md"
                app:boxStrokeColor="@color/border_subtle"
                app:hintEnabled="false"
                app:startIconDrawable="@android:drawable/ic_menu_my_calendar"
                app:startIconTint="@color/text_secondary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/dateEditText"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:clickable="true"
                    android:focusable="false"
                    android:inputType="none"
                    android:textColor="@color/text_primary"
                    android:textColorHint="@color/text_secondary"
                    android:textSize="@dimen/text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- Internship checkbox -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <CheckBox
                    android:id="@+id/checkBoxInternship"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="@color/accent_teal" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/space_xs"
                    android:text="This is an internship"
                    android:textColor="@color/text_primary"
                    android:textSize="@dimen/text_body_small" />

            </LinearLayout>

            <!-- Add button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/addJobApplication"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginTop="@dimen/space_lg"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:text="Update Application"
                android:textAllCaps="false"
                android:textColor="@color/bg_deepest"
                android:textSize="@dimen/text_body"
                android:textStyle="bold"
                app:backgroundTint="@color/accent_teal"
                app:cornerRadius="@dimen/radius_sm"
                app:rippleColor="#33000000" />

        </LinearLayout>

    </LinearLayout>
</ScrollView>